<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <title>DeepSeek AI 助手 - 华为设备友好版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Segoe UI', 'Roboto', 'Noto Sans', system-ui, -apple-system, 'HarmonyOS Sans', 'Helvetica Neue', sans-serif;
            background: linear-gradient(145deg, #f5f7fc 0%, #eef2f8 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* 主卡片容器 - 华为设备圆润风格 */
        .app-container {
            max-width: 900px;
            width: 100%;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(0px);
            border-radius: 48px;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25), 0 1px 2px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            transition: all 0.2s ease;
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* 头部区域 */
        .header {
            background: #ffffff;
            padding: 24px 28px 16px 28px;
            border-bottom: 1px solid #e9edf2;
        }

        .header h1 {
            font-size: 1.85rem;
            font-weight: 600;
            background: linear-gradient(135deg, #0c4e6e, #1a7f9e);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .header h1::before {
            content: "🤖";
            font-size: 1.9rem;
            background: none;
            -webkit-background-clip: unset;
            color: #1e7e9e;
        }

        .sub {
            color: #5b6e8c;
            margin-top: 8px;
            font-size: 0.9rem;
            font-weight: 400;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
        }

        /* API 密钥配置区域 */
        .api-section {
            background: #f8fafd;
            padding: 20px 28px;
            border-bottom: 1px solid #e2e8f0;
        }

        .input-group {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            margin-bottom: 12px;
        }

        .input-group label {
            font-weight: 600;
            color: #1e2a3e;
            min-width: 90px;
            font-size: 0.9rem;
        }

        .api-key-input {
            flex: 1;
            padding: 12px 16px;
            border: 1px solid #cbd5e1;
            border-radius: 60px;
            font-size: 0.9rem;
            background: white;
            transition: 0.2s;
            font-family: monospace;
        }

        .api-key-input:focus {
            outline: none;
            border-color: #1e7e9e;
            box-shadow: 0 0 0 3px rgba(30, 126, 158, 0.2);
        }

        .save-btn {
            background: #2c3e50;
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 60px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.85rem;
        }

        .save-btn:hover {
            background: #1e2f3f;
        }

        .key-status {
            font-size: 0.8rem;
            margin-top: 8px;
            color: #2c7a4d;
            background: #e6f4ea;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 40px;
        }

        /* 聊天区域 */
        .chat-messages {
            height: 420px;
            overflow-y: auto;
            padding: 20px 24px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* 自定义滚动条 华为风格 */
        .chat-messages::-webkit-scrollbar {
            width: 5px;
        }

        .chat-messages::-webkit-scrollbar-track {
            background: #eef2f6;
            border-radius: 10px;
        }

        .chat-messages::-webkit-scrollbar-thumb {
            background: #b9c4d1;
            border-radius: 10px;
        }

        .message {
            display: flex;
            flex-direction: column;
            max-width: 85%;
            animation: fadeInUp 0.2s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .user-message {
            align-self: flex-end;
        }

        .assistant-message {
            align-self: flex-start;
        }

        .message-bubble {
            padding: 12px 18px;
            border-radius: 28px;
            font-size: 0.95rem;
            line-height: 1.45;
            word-break: break-word;
            white-space: pre-wrap;
        }

        .user-message .message-bubble {
            background: #1a7f9e;
            color: white;
            border-bottom-right-radius: 6px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
        }

        .assistant-message .message-bubble {
            background: #f0f2f5;
            color: #1e2f3e;
            border-bottom-left-radius: 6px;
            border: 1px solid #e2e8f0;
        }

        .message-time {
            font-size: 0.7rem;
            margin: 4px 12px 0;
            color: #8e9eae;
        }

        /* 输入区域 */
        .input-area {
            padding: 18px 24px 24px;
            background: #ffffff;
            border-top: 1px solid #eef2f8;
            display: flex;
            gap: 12px;
            align-items: flex-end;
        }

        .input-wrapper {
            flex: 1;
            background: #f7f9fc;
            border-radius: 36px;
            border: 1px solid #dfe5ec;
            transition: 0.2s;
            padding: 6px 8px 6px 20px;
            display: flex;
            align-items: center;
        }

        .input-wrapper:focus-within {
            border-color: #1a7f9e;
            box-shadow: 0 0 0 3px rgba(26, 127, 158, 0.15);
            background: white;
        }

        #userInput {
            flex: 1;
            border: none;
            background: transparent;
            padding: 12px 8px;
            font-size: 0.95rem;
            resize: none;
            font-family: inherit;
            max-height: 120px;
            outline: none;
        }

        #sendBtn {
            background: #1a7f9e;
            border: none;
            color: white;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.9rem;
            margin-left: 6px;
        }

        #sendBtn:hover:not(:disabled) {
            background: #0e5f78;
            transform: scale(0.97);
        }

        #sendBtn:disabled {
            background: #9bb4c2;
            cursor: not-allowed;
            opacity: 0.7;
        }

        .loading-indicator {
            display: flex;
            gap: 6px;
            padding: 8px 16px;
            background: #f0f2f5;
            border-radius: 28px;
            width: fit-content;
            font-size: 0.8rem;
            color: #3e5a6b;
        }

        .dot-floating {
            display: flex;
            gap: 4px;
        }

        .dot-floating span {
            width: 8px;
            height: 8px;
            background: #5f7f9a;
            border-radius: 50%;
            display: inline-block;
            animation: bounce 1.2s infinite;
        }

        .dot-floating span:nth-child(2) {
            animation-delay: 0.2s;
        }
        .dot-floating span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes bounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-5px); }
        }

        .footer-note {
            font-size: 0.7rem;
            text-align: center;
            padding: 12px;
            background: #fafcff;
            border-top: 1px solid #edf2f7;
            color: #6c819a;
        }

        button.clear-chat {
            background: none;
            border: none;
            color: #8a9bb0;
            font-size: 0.75rem;
            cursor: pointer;
            margin-left: 12px;
        }

        button.clear-chat:hover {
            color: #d9534f;
        }

        @media (max-width: 600px) {
            .app-container {
                border-radius: 32px;
            }
            .header h1 {
                font-size: 1.5rem;
            }
            .message {
                max-width: 92%;
            }
            .input-area {
                padding: 14px 18px 20px;
            }
            .api-section {
                padding: 16px 20px;
            }
        }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <h1>DeepSeek 智慧助手</h1>
        <div class="sub">
            <span>✨ 基于官方API · 华为终端深度适配</span>
            <button id="clearHistoryBtn" class="clear-chat">🗑️ 清空对话</button>
        </div>
    </div>

    <div class="api-section">
        <div class="input-group">
            <label>🔑 API Key</label>
            <input type="password" id="apiKeyInput" class="api-key-input" placeholder="sk-xxxxxxxxxxxxxxxxxxxx" autocomplete="off">
            <button id="saveKeyBtn" class="save-btn">保存密钥</button>
        </div>
        <div id="keyStatus" class="key-status">sk-2603431dbbd94710bdf0f787c694e25a Key</div>
        <div style="font-size: 0.7rem; margin-top: 8px; color:#678;">
            💡 提示：密钥仅存储在您的浏览器本地(localStorage)，不会上传任何服务器。支持华为浏览器/鸿蒙系统。
        </div>
    </div>

    <div id="chatMessages" class="chat-messages">
        <div class="message assistant-message">
            <div class="message-bubble">
                👋 你好！我是DeepSeek AI助手。请在上方输入你的API密钥（可从 platform.deepseek.com 获取），然后向我提问吧！<br>🚀 华为设备体验优化，响应快速。
            </div>
            <div class="message-time">刚刚</div>
        </div>
    </div>

    <div class="input-area">
        <div class="input-wrapper">
            <textarea id="userInput" rows="1" placeholder="输入消息... (Enter发送，Shift+Enter换行)" style="overflow-y: auto;"></textarea>
        </div>
        <button id="sendBtn">发送 ✨</button>
    </div>
    <div class="footer-note">
        🌐 数据通过 DeepSeek 官方 API (https://api.deepseek.com/v1/chat/completions) 加密传输 · 对话历史仅本地保存
    </div>
</div>

<script>
    // ---------- DOM 元素绑定 ----------
    const apiKeyInput = document.getElementById('apiKeyInput');
    const saveKeyBtn = document.getElementById('saveKeyBtn');
    const keyStatusDiv = document.getElementById('keyStatus');
    const chatContainer = document.getElementById('chatMessages');
    const userInput = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const clearHistoryBtn = document.getElementById('clearHistoryBtn');

    // ---------- 全局状态 ----------
    let currentApiKey = '';          // 当前有效api key
    let messagesHistory = [];         // 存储对话历史 { role, content } 用于上下文
    let isLoading = false;            // 请求锁，防止并发

    // 从localStorage加载API Key和聊天记录
    function loadStoredData() {
        const storedKey = localStorage.getItem('deepseek_api_key');
        if (storedKey) {
            currentApiKey = storedKey;
            apiKeyInput.value = storedKey;
            updateKeyStatus(true);
        } else {
            updateKeyStatus(false);
        }

        // 加载历史消息 (数组)
        const storedHistory = localStorage.getItem('deepseek_chat_history');
        if (storedHistory) {
            try {
                const parsed = JSON.parse(storedHistory);
                if (Array.isArray(parsed)) {
                    messagesHistory = parsed;
                    renderMessagesFromHistory();
                } else {
                    messagesHistory = [];
                }
            } catch(e) { messagesHistory = []; }
        }
        // 如果没有历史，确保至少有一条欢迎消息但避免重复添加欢迎消息
        if (messagesHistory.length === 0) {
            // 添加一条初始助手消息
            messagesHistory.push({
                role: 'assistant',
                content: '👋 你好！我是DeepSeek AI助手。请在上方输入你的API密钥（可从 platform.deepseek.com 获取），然后向我提问吧！\n🚀 华为设备体验优化，响应快速。'
            });
            saveChatHistory();
            renderMessagesFromHistory();
        } else {
            renderMessagesFromHistory();
        }
    }

    // 更新密钥状态显示
    function updateKeyStatus(isValid) {
        if (isValid) {
            const masked = maskApiKey(currentApiKey);
            keyStatusDiv.innerHTML = `✅ API密钥已配置 (${masked}) · 请求将使用官方接口`;
            keyStatusDiv.style.background = "#e0f2e9";
            keyStatusDiv.style.color = "#0e6245";
        } else {
            keyStatusDiv.innerHTML = `⚠️ 未配置有效的API Key，请在上方输入DeepSeek官方的API Key并保存`;
            keyStatusDiv.style.background = "#fff1e0";
            keyStatusDiv.style.color = "#b45f06";
        }
    }

    function maskApiKey(key) {
        if (!key) return '未设置';
        if (key.length <= 10) return '***';
        return key.slice(0, 6) + '...' + key.slice(-4);
    }

    // 保存API Key
    function saveApiKey() {
        let newKey = apiKeyInput.value.trim();
        if (newKey === '') {
            alert('请输入有效的DeepSeek API Key');
            return;
        }
        // 简单校验格式 sk-开头 (官方Key通常以sk-开头)
        if (!newKey.startsWith('sk-') && !newKey.startsWith('sk-proj-')) {
            if (!confirm('API Key通常以sk-开头，确认这是正确的DeepSeek密钥吗？')) {
                return;
            }
        }
        currentApiKey = newKey;
        localStorage.setItem('deepseek_api_key', currentApiKey);
        updateKeyStatus(true);
        alert('✅ API密钥已安全保存至本地浏览器');
    }

    // 保存聊天历史到localStorage
    function saveChatHistory() {
        localStorage.setItem('deepseek_chat_history', JSON.stringify(messagesHistory));
    }

    // 渲染消息 (从messagesHistory)
    function renderMessagesFromHistory() {
        if (!chatContainer) return;
        // 保留滚动位置之前先记录是否滚动到底部 (自动滚动)
        const shouldScroll = chatContainer.scrollHeight - chatContainer.scrollTop - chatContainer.clientHeight < 30;
        chatContainer.innerHTML = '';
        for (let msg of messagesHistory) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${msg.role === 'user' ? 'user-message' : 'assistant-message'}`;
            const bubble = document.createElement('div');
            bubble.className = 'message-bubble';
            // 支持换行显示
            bubble.innerText = msg.content;
            const timeSpan = document.createElement('div');
            timeSpan.className = 'message-time';
            const now = new Date();
            timeSpan.innerText = `${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
            messageDiv.appendChild(bubble);
            messageDiv.appendChild(timeSpan);
            chatContainer.appendChild(messageDiv);
        }
        if (shouldScroll || messagesHistory.length > 0) {
            scrollToBottom();
        }
    }

    // 添加新消息并更新UI和历史
    function addMessageToUI(role, content) {
        messagesHistory.push({ role, content });
        saveChatHistory();
        renderMessagesFromHistory();
    }

    // 仅追加最后一条loading信息 (非永久保存)
    let loadingMessageElement = null;

    function showTypingIndicator() {
        removeTypingIndicator();
        const loadingDiv = document.createElement('div');
        loadingDiv.className = 'message assistant-message';
        loadingDiv.id = 'typingIndicator';
        loadingDiv.innerHTML = `
            <div class="message-bubble" style="background:#f0f2f5; padding: 12px 18px;">
                <div class="dot-floating">
                    <span></span><span></span><span></span>
                </div>
                <span style="margin-left: 8px;">DeepSeek 思考中...</span>
            </div>
        `;
        chatContainer.appendChild(loadingDiv);
        scrollToBottom();
    }

    function removeTypingIndicator() {
        const indicator = document.getElementById('typingIndicator');
        if (indicator) indicator.remove();
    }

    function scrollToBottom() {
        if (chatContainer) {
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }
    }

    // 调用DeepSeek官方API (非流式，简单可靠，支持华为设备)
    async function callDeepSeekAPI(userQuestion) {
        if (!currentApiKey) {
            throw new Error('API_KEY_MISSING');
        }
        // 构建请求消息体：需要把历史对话除了最后即将插入的user消息外传入, 但messagesHistory包含历史所有消息
        // 为了控制上下文长度，保留最近15条对话，避免tokens溢出。但此处保留完整(只要不过长)
        let apiMessages = [];
        // 限制上下文长度: 最多保留最近10条来回 (即20条消息) 以防超长
        const contextLimit = 20;
        let historyToSend = messagesHistory.slice(-contextLimit);
        for (let msg of historyToSend) {
            apiMessages.push({
                role: msg.role,
                content: msg.content
            });
        }
        // 添加当前用户问题 (注意防止重复添加：外部在调用callDeepSeekAPI之前应该还未添加用户消息到messagesHistory，但方便统一，我们在外面先将用户消息push进历史，然后调用时从历史拿)
        // 但为了设计干净: 我们在调用前已经将用户消息加入messagesHistory, 所以上面historyToSend已经包含了最新的用户消息
        // 不需要额外添加

        const requestBody = {
            model: 'deepseek-chat',
            messages: apiMessages,
            temperature: 0.7,
            max_tokens: 2000,
            stream: false
        };

        const response = await fetch('https://api.deepseek.com/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${currentApiKey}`
            },
            body: JSON.stringify(requestBody)
        });

        if (!response.ok) {
            let errorDetail = `HTTP ${response.status}`;
            try {
                const errJson = await response.json();
                errorDetail = errJson.error?.message || JSON.stringify(errJson);
            } catch(e) {}
            throw new Error(`API请求失败: ${errorDetail}`);
        }

        const data = await response.json();
        if (!data.choices || !data.choices[0] || !data.choices[0].message) {
            throw new Error('响应格式异常');
        }
        const assistantReply = data.choices[0].message.content;
        return assistantReply;
    }

    // 主要发送消息逻辑
    async function sendMessage() {
        if (isLoading) {
            return;
        }
        const question = userInput.value.trim();
        if (!question) {
            return;
        }
        // 检查API Key
        if (!currentApiKey) {
            alert('请先保存DeepSeek API Key (获取地址: https://platform.deepseek.com/)');
            return;
        }

        // 清空输入框
        userInput.value = '';
        // 重置高度
        userInput.style.height = 'auto';

        // 将用户消息添加到历史并显示
        addMessageToUI('user', question);
        isLoading = true;
        sendBtn.disabled = true;
        saveKeyBtn.disabled = true;   // 发送时暂时禁用保存key操作
        showTypingIndicator();

        try {
            const assistantReply = await callDeepSeekAPI(question);
            removeTypingIndicator();
            // 添加助手回复到历史
            addMessageToUI('assistant', assistantReply);
        } catch (error) {
            removeTypingIndicator();
            console.error('DeepSeek API 调用错误:', error);
            let errorMsg = '❌ 请求失败: ';
            if (error.message === 'API_KEY_MISSING') {
                errorMsg = '🔑 未配置API Key，请先保存有效的DeepSeek密钥。';
            } else if (error.message.includes('401') || error.message.includes('Unauthorized')) {
                errorMsg = '🔒 API Key无效或已过期，请检查你的DeepSeek密钥。';
            } else if (error.message.includes('429')) {
                errorMsg = '⏱️ 请求过于频繁，请稍后再试。';
            } else {
                errorMsg += error.message;
            }
            addMessageToUI('assistant', `⚠️ 发生错误: ${errorMsg}\n\n建议：\n- 确认API Key有效且有余额\n- 检查网络连接（鸿蒙/安卓网络正常）\n- 尝试重新保存密钥`);
        } finally {
            isLoading = false;
            sendBtn.disabled = false;
            saveKeyBtn.disabled = false;
            userInput.focus();
        }
    }

    // 清空对话历史 (保留API Key，重置会话)
    function clearChatHistory() {
        if (isLoading) {
            alert('请等待当前请求完成后再清空对话');
            return;
        }
        // 重置历史数组，仅保留一条新的欢迎消息
        messagesHistory = [{
            role: 'assistant',
            content: '✨ 对话已重置。我是DeepSeek AI助手，有什么我可以帮你的吗？ (API密钥已保留)'
        }];
        saveChatHistory();
        renderMessagesFromHistory();
        // 滚动到底部
        scrollToBottom();
    }

    // 自适应textarea高度
    function autoResizeTextarea() {
        userInput.style.height = 'auto';
        let newHeight = Math.min(userInput.scrollHeight, 120);
        userInput.style.height = newHeight + 'px';
    }

    // 绑定事件与初始化
    function bindEvents() {
        saveKeyBtn.addEventListener('click', saveApiKey);
        sendBtn.addEventListener('click', sendMessage);
        clearHistoryBtn.addEventListener('click', clearChatHistory);
        userInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
        userInput.addEventListener('input', autoResizeTextarea);
    }

    // 初始化: 加载数据 + 绑定事件
    function init() {
        bindEvents();
        loadStoredData();
        // 自动聚焦输入框
        userInput.focus();
        // 额外处理华为设备软键盘遮挡问题（轻微滚动）
        window.addEventListener('resize', () => {
            setTimeout(() => {
                if (document.activeElement === userInput) {
                    scrollToBottom();
                }
            }, 100);
        });
    }

    init();
</script>
</body>
</html>
